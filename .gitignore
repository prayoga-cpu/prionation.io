# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
**/.DS_Store
*.pem

# editors — ignore personal/local editor config
.vscode/
.idea/

# claude code — commit shared project settings; ignore personal/local overrides
.claude/settings.local.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# graphify — commit the queryable graph + report so every clone/agent has one;
# ignore local-only artifacts, caches, and machine-specific interpreter paths
graphify-out/*
!graphify-out/graph.json
!graphify-out/GRAPH_REPORT.md
